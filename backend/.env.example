# App
PORT=5000
FRONTEND_URL=http://localhost:5173

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/skillswap

# Password reset email (pick ONE style: well-known service OR custom SMTP)

# Option A — Gmail (use an App Password: Google Account → Security → 2-Step → App passwords)
EMAIL_SERVICE=Gmail
EMAIL_USER=you@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM=SkillSwap <you@gmail.com>

# Option B — Any SMTP host (Office365, SendGrid SMTP, etc.)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# SMTP_USER=you@gmail.com
# SMTP_PASS=app_password
